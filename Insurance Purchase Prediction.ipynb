import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import io

from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, classification_report, ConfusionMatrixDisplay

from sklearn.linear_model import LogisticRegression
from sklearn.neighbors import KNeighborsClassifier
from sklearn.svm import SVC
from sklearn.tree import DecisionTreeClassifier
from sklearn.ensemble import RandomForestClassifier
from sklearn.neural_network import MLPClassifier

from google.colab import files


# ===============================
# 1. Load Dataset
# ===============================
def load_data():
    print("Upload CSV file (must contain Age, EstimatedSalary, Purchased):")
    uploaded = files.upload()

    if not uploaded:
        print("No file uploaded!")
        return None

    file_name = list(uploaded.keys())[0]
    df = pd.read_csv(io.BytesIO(uploaded[file_name]))

    required_cols = {'Age', 'EstimatedSalary', 'Purchased'}
    if not required_cols.issubset(df.columns):
        print("Dataset must contain Age, EstimatedSalary, Purchased")
        return None

    print("\nDataset Preview:")
    print(df.head())

    return df


# ===============================
# 2. Preprocessing
# ===============================
def preprocess_data(df):
    X = df[['Age', 'EstimatedSalary']].copy()
    y = df['Purchased']

    # Fill missing salary values safely
    median_salary = X['EstimatedSalary'].median()
    X['EstimatedSalary'] = X['EstimatedSalary'].fillna(median_salary)

    return X, y


# ===============================
# 3. Train Models
# ===============================
def train_models(X_train_scaled, y_train):
    models = {
        'Logistic Regression': LogisticRegression(),
        'KNN': KNeighborsClassifier(n_neighbors=5),
        'SVM': SVC(kernel='rbf'),
        'Decision Tree': DecisionTreeClassifier(),
        'Random Forest': RandomForestClassifier(n_estimators=100, random_state=42),
        'Neural Network': MLPClassifier(hidden_layer_sizes=(10, 10), max_iter=1000)
    }

    return models


# ===============================
# 4. Evaluate Models
# ===============================
def evaluate_models(models, X_test_scaled, y_test):
    results = []

    for name, model in models.items():
        model.fit(X_train_scaled, y_train)
        y_pred = model.predict(X_test_scaled)

        accuracy = accuracy_score(y_test, y_pred)
        precision = precision_score(y_test, y_pred, zero_division=0)
        recall = recall_score(y_test, y_pred, zero_division=0)
        f1 = f1_score(y_test, y_pred, zero_division=0)

        results.append([name, accuracy, precision, recall, f1])

    results_df = pd.DataFrame(results, columns=['Model', 'Accuracy', 'Precision', 'Recall', 'F1 Score'])

    print("\nModel Comparison:")
    print(results_df.sort_values(by='Accuracy', ascending=False))

    return results_df


# ===============================
# 5. Visualization
# ===============================
def plot_data(df):
    plt.figure(figsize=(8, 5))
    sns.scatterplot(data=df, x='Age', y='EstimatedSalary', hue='Purchased', palette='Set1')
    plt.title("Age vs Salary Distribution")
    plt.grid(True)
    plt.show()


# ===============================
# 6. Custom Predictions
# ===============================
def predict_custom(best_model, scaler, median_salary):
    print("\nCustom Predictions:")

    custom_data = pd.DataFrame({
        'Age': [30, 40, 40, 50, 18, 22, 35, 60],
        'EstimatedSalary': [
            87000,
            median_salary,
            100000,
            median_salary,
            median_salary,
            600000,
            2500000,
            100000000
        ]
    })

    custom_scaled = scaler.transform(custom_data)
    preds = best_model.predict(custom_scaled)

    for age, sal, pred in zip(custom_data['Age'], custom_data['EstimatedSalary'], preds):
        print(f"Age: {age}, Salary: {sal:,} → {'Purchased' if pred == 1 else 'Not Purchased'}")


# ===============================
# MAIN FUNCTION
# ===============================
def main():
    global X_train_scaled, y_train

    df = load_data()
    if df is None:
        return

    X, y = preprocess_data(df)

    # Train-test split
    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=0.25, random_state=42
    )

    # Scaling
    scaler = StandardScaler()
    X_train_scaled = scaler.fit_transform(X_train)
    X_test_scaled = scaler.transform(X_test)

    # Train models
    models = train_models(X_train_scaled, y_train)

    # Evaluate
    results_df = evaluate_models(models, X_test_scaled, y_test)

    # Select best model automatically
    best_model_name = results_df.sort_values(by='Accuracy', ascending=False).iloc[0]['Model']
    best_model = models[best_model_name]

    print(f"\nBest Model: {best_model_name}")

    # Train best model again
    best_model.fit(X_train_scaled, y_train)

    # Final evaluation
    y_pred = best_model.predict(X_test_scaled)

    print("\nClassification Report:")
    print(classification_report(y_test, y_pred))

    # Confusion Matrix
    ConfusionMatrixDisplay.from_estimator(best_model, X_test_scaled, y_test, cmap="Blues")
    plt.title("Confusion Matrix")
    plt.show()

    # Plot data
    plot_data(df)

    # Custom predictions
    median_salary = X['EstimatedSalary'].median()
    predict_custom(best_model, scaler, median_salary)


# Run
if __name__ == "__main__":
    main()
